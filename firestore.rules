rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function hasCallerDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Safe accessor for caller data; returns empty object if missing.
    function callerData() {
      return hasCallerDoc()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }

    function callerCompany() {
      return hasCallerDoc() ? callerData().company : null;
    }

    function isSuperAdmin() {
      return hasCallerDoc() && callerData().role == 'SUPER_ADMIN';
    }

    // ── /users ────────────────────────────────────────────────────────────────
    // • Own doc: always readable/writable by the owner (needed by AuthContext
    //   onSnapshot and the activation flow in Signup.jsx).
    // • Other users' docs: readable if they belong to the same company.
    // • Pending-signup docs (created by Admin, no UID yet): any authenticated
    //   user may read them so Signup.jsx can query by email + status.
    // • Delete: owner can delete their own; SUPER_ADMIN can delete any;
    //   activation flow can delete the temp pending_signup doc.

    match /users/{userId} {
      // All authenticated users can read any user doc (global user visibility).
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (
        isOwner(userId) ||                          // activation writes own UID doc
        isSuperAdmin() ||                           // super admin creates users
        // Any authenticated admin can create a pending_signup doc without
        // requiring a company match (users are now global, not company-scoped).
        request.resource.data.status == 'pending_signup'
      );
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        isSuperAdmin() ||
        resource.data.status == 'pending_signup'   // activation flow promotes doc
      );
      allow delete: if isAuthenticated() && (
        isOwner(userId) ||
        isSuperAdmin() ||
        resource.data.status == 'pending_signup' // activation cleans up temp doc
      );
    }

    // ── /companies ────────────────────────────────────────────────────────────
    // All authenticated users need to read the company list (AuthContext).
    // Only SUPER_ADMIN may create / update / delete companies.

    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && isSuperAdmin();
    }

    // ── Stock collections (global read) ──────────────────────────────────────
    // All authenticated users can read all records across all companies.
    // Create / update / delete remain company-scoped.

    match /incomingStock/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || (callerCompany() != null && request.resource.data.company == callerCompany()));
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || (callerCompany() != null && resource.data.company == callerCompany()));
    }

    match /outgoingStock/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || (callerCompany() != null && request.resource.data.company == callerCompany()));
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || (callerCompany() != null && resource.data.company == callerCompany()));
    }

    match /returns/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isSuperAdmin() || (callerCompany() != null && request.resource.data.company == callerCompany()));
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || (callerCompany() != null && resource.data.company == callerCompany()));
    }

    // ── All other collections ─────────────────────────────────────────────────
    // Data is scoped to the caller's company.

    match /{collection}/{docId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() ||
        (callerCompany() != null && resource.data.company == callerCompany())
      );
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (callerCompany() != null && request.resource.data.company == callerCompany())
      );
      allow update, delete: if isAuthenticated() && (
        isSuperAdmin() ||
        (callerCompany() != null && resource.data.company == callerCompany())
      );
    }

    // Cover nested sub-collections (e.g. future use).
    match /{collection}/{docId}/{rest=**} {
      allow read, write: if isAuthenticated() && (
        isSuperAdmin() || (
          callerCompany() != null &&
          get(/databases/$(database)/documents/$(collection)/$(docId)).data.company == callerCompany()
        )
      );
    }
  }
}
